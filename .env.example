# PostgreSQL 연결 문자열 (Neon 권장). 풀링 연결.
DATABASE_URL=""

# Neon 등에서 마이그레이션 시 사용하는 direct(non-pooled) 연결 문자열.
DIRECT_URL=""

# 한국관광공사 공공데이터포털 서비스 키 (Decoding key). 서버에서만 사용, 절대 클라이언트에 노출하지 않는다.
TOUR_API_SERVICE_KEY=""

# 공공데이터 기준월 (YYYYMM). 현재 확인된 제공 기준월은 202509.
TOUR_DATA_BASE_YM="202509"

# 카카오맵 JavaScript 키. 없으면 좌표/주소 fallback UI로 자동 전환된다.
NEXT_PUBLIC_KAKAO_MAP_KEY=""

# 배포된 앱의 절대 URL (로컬 개발 시 http://localhost:3000).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# live | hybrid | snapshot. hybrid: 라이브 실패 축만 마지막 성공 스냅샷으로 대체.
DATA_MODE="hybrid"

# /api/cron/sync-tourism-data, /api/admin/sync-tourism-data 인증에 사용하는 비밀값.
CRON_SECRET=""
